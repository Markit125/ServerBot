BOT_TOKEN = "YOUR_BOT_TOKEN_FROM_BOTFATHER"

# Optional: path to the main TOML config.
# If omitted, the bot tries ./config.toml and continues with defaults
# when that file does not exist.
#
# SERVERBOT_CONFIG = "./config.toml"

# Optional: credentials used by the local telegram-bot-api service.
# The bot itself does not read these values yet, but keeping them here
# is convenient if the local Bot API service loads the same environment.
#
# TELEGRAM_API_ID = "YOUR_API_ID"
# TELEGRAM_API_HASH = "YOUR_API_HASH"

# Optional access overrides. Prefer config.toml for normal setup.
#
# SERVERBOT_ACCESS_ENABLED = "true"
# SERVERBOT_ALLOWED_USER_IDS = "123456789,987654321"
# SERVERBOT_ACCESS_DENY_MESSAGE = "Access denied"

# Optional wrapper log maintenance. These are read by scripts/run-serverbot.sh.
# LOG_MAX_BYTES: shrink logs/serverbot.log when it grows past this size.
# LOG_KEEP_BYTES: keep only this many bytes from the end when shrinking.
# LOG_SHRINK_INTERVAL_SECONDS: how often to check logs; 0 disables background checks.
# RUN_LOG_MAX_AGE_DAYS: delete serverbot-run.*.log older than this many days.
# RUN_LOG_MAX_FILES: keep only this many newest serverbot-run.*.log files.
#
# LOG_MAX_BYTES = "52428800"
# LOG_KEEP_BYTES = "10485760"
# LOG_SHRINK_INTERVAL_SECONDS = "300"
# RUN_LOG_MAX_AGE_DAYS = "7"
# RUN_LOG_MAX_FILES = "20"
